# ================================================
# chaos-creation Homelab - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================

# Host Configuration
HOST_IP=192.168.0.112
HOST_USER=your_username
TIMEZONE=Asia/Kolkata

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# Pi-hole
PIHOLE_WEB_PASSWORD=changeme

# qBittorrent
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=changeme

# VPN (ProtonVPN/Mullvad)
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=openvpn
OPENVPN_USER=your_vpn_username
OPENVPN_PASSWORD=your_vpn_password
VPN_SERVER_COUNTRY=Netherlands

# Portainer
PORTAINER_ADMIN_PASSWORD=changeme
